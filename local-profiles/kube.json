{
  "extends": "default",
  "meta": {
    "name": "kubectl-helm-demo",
    "version": "1.0.0",
    "description": "Kubernetes command policy demo keyed on kubectl and helm identities",
    "author": "k8s-automation"
  },
  "security": {
    "signal_mode": "isolated"
  },
  "filesystem": {},
  "network": {
    "block": false
  },
  "workdir": {
    "access": "none"
  },
  "interactive": false,
  "command_policies": {
    "session_can_use": [
      "kubectl",
      "helm"
    ],
    "credentials": {
      "kubeconfig": {
        "type": "raw-file",
        "path": "/Users/lukehinds/.kube/config"
      }
    },
    "commands": {
      "kubectl": {
        "sandbox": {
          "use_credentials": [
            "kubeconfig"
          ],
          "fs_read": [
            ".",
            "$HOME/.kube"
          ],
          "fs_write": [
            ".",
            "$TMPDIR"
          ],
          "fs_read_file": [
            "$HOME/.kube/config"
          ],
          "environment": {
            "allow_vars": [
              "PATH",
              "HOME",
              "TMPDIR",
              "KUBECONFIG",
              "KUBE_NAMESPACE",
              "KUBE_CONTEXT"
            ]
          },
          "network": {
            "allow_all": true
          }
        },
        "intercept": [
          {
            "args": [
              "delete"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 60
            }
          },
          {
            "args": [
              "drain"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 60
            }
          },
          {
            "args": [
              "cordon"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 60
            }
          },
          {
            "args": [
              "uncordon"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 60
            }
          },
          {
            "args": [
              "create",
              "clusterrolebinding"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 60
            }
          },
          {
            "args": [
              "auth",
              "reconcile"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 60
            }
          },
          {
            "args": [
              "replace",
              "--force"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 60
            }
          }
        ]
      },
      "helm": {
        "sandbox": {
          "use_credentials": [
            "kubeconfig"
          ],
          "fs_read": [
            "."
          ],
          "fs_write": [
            ".",
            "$TMPDIR"
          ],
          "fs_read_file": [
            "$HOME/.config/helm/repositories.yaml",
            "$HOME/.kube/config"
          ],
          "environment": {
            "allow_vars": [
              "PATH",
              "HOME",
              "TMPDIR",
              "HELM_*",
              "KUBECONFIG",
              "KUBE_NAMESPACE"
            ]
          },
          "network": {
            "allow_all": true
          }
        }
      }
    }
  }
}
