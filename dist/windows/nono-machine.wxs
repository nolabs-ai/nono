<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="nono"
      Manufacturer="Luke Hinds"
      Version="0.53.0"
      UpgradeCode="D5948D55-89A4-4F09-AB43-44DBA9D25D1A"
      Scope="perMachine">
    <SummaryInformation
        Description="nono Windows native installer (administrative install)"
        Manufacturer="Luke Hinds" />
    <MajorUpgrade
        DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <Property Id="ARPCOMMENTS" Value="nono Windows native installer (administrative install)" />
    <Property Id="ARPCONTACT" Value="Luke Hinds" />
    <Property Id="ARPURLHELP" Value="https://docs.nono.sh/cli/getting_started/installation" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/always-further/nono" />
    <Property Id="ARPURLUPDATEINFO" Value="https://github.com/always-further/nono/releases" />
    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Feature Id="MainFeature" Title="nono" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="nono" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="cmpNonoExe" Guid="*">
        <File Id="filNonoExe" Source="C:\Users\OMack\Nono\target\x86_64-pc-windows-msvc\release\nono.exe" KeyPath="yes" />
      </Component>
      <Component Id="cmpNonoShellBrokerExe" Guid="*">
        <!-- Phase 31 Plan 04: nono-shell-broker.exe lives under INSTALLFOLDER
             (the ComponentGroup's Directory attribute) so both binaries install
             to the same dir at runtime. Satisfies D-07 sibling resolution
             (current_exe().parent() finds the broker) for both machine scope
             (Program Files\nono\) and user scope (LocalAppData\Programs\nono\).
             No scope guard needed â€” broker is required for both MSIs. -->
        <File Id="filNonoShellBrokerExe" Source="C:\Users\OMack\Nono\target\x86_64-pc-windows-msvc\release\nono-shell-broker.exe" KeyPath="yes" />
      </Component>
      <Component Id="cmpReadme" Guid="*">
        <File Id="filReadme" Source="C:\Users\OMack\Nono\README.md" Name="README.md" KeyPath="yes" />
      </Component>
      <Component Id="cmpLicense" Guid="*">
        <File Id="filLicense" Source="C:\Users\OMack\Nono\LICENSE" Name="LICENSE" KeyPath="yes" />
      </Component>
      <Component Id="cmpPath" Guid="*">
        <RegistryValue
            Root="HKLM"
            Key="Software\always-further\nono\machine"
            Name="InstallDir"
            Type="string"
            Value="[INSTALLFOLDER]"
            KeyPath="yes" />
        <Environment
            Id="EnvPath"
            Name="PATH"
            Action="set"
            Part="last"
            Permanent="no"
            System="yes"
            Value="[INSTALLFOLDER]" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>