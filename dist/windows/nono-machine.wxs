<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="nono"
      Manufacturer="Luke Hinds and Oscar Mack Jr"
      Version="0.53.1"
      UpgradeCode="D5948D55-89A4-4F09-AB43-44DBA9D25D1A"
      Scope="perMachine">
    <SummaryInformation
        Description="nono Windows native installer (administrative install)"
        Manufacturer="Luke Hinds and Oscar Mack Jr" />
    <MajorUpgrade
        DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <Property Id="ARPCOMMENTS" Value="nono Windows native installer (administrative install)" />
    <Property Id="ARPCONTACT" Value="Luke Hinds and Oscar Mack Jr" />
    <Property Id="ARPURLHELP" Value="https://docs.nono.sh/cli/getting_started/installation" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/always-further/nono" />
    <Property Id="ARPURLUPDATEINFO" Value="https://github.com/always-further/nono/releases" />
    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Feature Id="MainFeature" Title="nono" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="nono" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="cmpNonoExe" Guid="*">
        <File Id="filNonoExe" Source="C:\Users\OMack\Nono\target\x86_64-pc-windows-msvc\release\nono.exe" KeyPath="yes" />
      </Component>
      <Component Id="cmpNonoShellBrokerExe" Guid="*">
        <!-- Phase 31 Plan 04: nono-shell-broker.exe lives under INSTALLFOLDER
             (the ComponentGroup's Directory attribute) so both binaries install
             to the same dir at runtime. Satisfies D-07 sibling resolution
             (current_exe().parent() finds the broker) for both machine scope
             (Program Files\nono\) and user scope (LocalAppData\Programs\nono\).
             No scope guard needed â€” broker is required for both MSIs. -->
        <File Id="filNonoShellBrokerExe" Source="C:\Users\OMack\Nono\target\x86_64-pc-windows-msvc\release\nono-shell-broker.exe" KeyPath="yes" />
      </Component>
      <Component Id="cmpReadme" Guid="*">
        <File Id="filReadme" Source="C:\Users\OMack\Nono\README.md" Name="README.md" KeyPath="yes" />
      </Component>
      <Component Id="cmpLicense" Guid="*">
        <File Id="filLicense" Source="C:\Users\OMack\Nono\LICENSE" Name="LICENSE" KeyPath="yes" />
      </Component>
      <Component Id="cmpPath" Guid="*">
        <RegistryValue
            Root="HKLM"
            Key="Software\always-further\nono\machine"
            Name="InstallDir"
            Type="string"
            Value="[INSTALLFOLDER]"
            KeyPath="yes" />
        <Environment
            Id="EnvPath"
            Name="PATH"
            Action="set"
            Part="last"
            Permanent="no"
            System="yes"
            Value="[INSTALLFOLDER]" />
      </Component>
      <!-- Quick task 260522-c9c: WFP backend components for the machine-scope
           MSI. The runtime probe (exec_strategy_windows::network::probe_wfp_runtime)
           looks for both files at INSTALLFOLDER\nono-wfp-service.exe and
           INSTALLFOLDER\nono-wfp-driver.sys as siblings of nono.exe; missing
           either fails closed with a BackendBinaryMissing directive.

           This hand-edited reference snapshot matches what
           `scripts/build-windows-msi.ps1 -Scope machine -ServiceBinaryPath ... -DriverBinaryPath ...`
           emits at CI time. The local Source paths reflect the dev-host
           project root; the release MSI is generated by the PowerShell
           script with workspace-relative resolved paths. -->
      <Component Id="cmpWfpServiceExe" Guid="*">
        <File Id="filWfpServiceExe" Source="C:\Users\OMack\Nono\target\x86_64-pc-windows-msvc\release\nono-wfp-service.exe" KeyPath="yes" />
        <ServiceInstall
            Id="svcWfpService"
            Name="nono-wfp-service"
            DisplayName="nono WFP Service"
            Description="nono Windows Filtering Platform backend service"
            Type="ownProcess"
            Start="demand"
            Account="LocalSystem"
            ErrorControl="normal"
            Arguments="--service-mode" />
        <ServiceControl
            Id="svcCtrlWfpService"
            Name="nono-wfp-service"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />
      </Component>
      <Component Id="cmpWfpDriverSys" Guid="*">
        <!-- Driver source is the checked-in pre-signed copy under
             crates/nono-cli/data/windows/, NOT the dev build artifact under
             target/. Kernel driver registration (via sc.exe with
             SERVICE_KERNEL_DRIVER type) is handled by the CLI command
             `nono setup install-wfp-driver` post-install; WiX's ServiceInstall
             element cannot model kernel drivers. -->
        <File Id="filWfpDriverSys" Source="C:\Users\OMack\Nono\crates\nono-cli\data\windows\nono-wfp-driver.sys" Name="nono-wfp-driver.sys" KeyPath="yes" />
      </Component>
      <Component Id="cmpEventLogSource" Guid="*">
        <RegistryKey
            Root="HKLM"
            Key="SYSTEM\CurrentControlSet\Services\EventLog\Application\nono-wfp-service">
          <RegistryValue
              Name="EventMessageFile"
              Type="string"
              Value="[INSTALLFOLDER]nono-wfp-service.exe"
              KeyPath="yes" />
          <RegistryValue
              Name="TypesSupported"
              Type="integer"
              Value="7" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>